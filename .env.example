# ShopArk configuration.
# Copy to .env.local and fill in what you have — the app runs in demo
# mode with NO credentials at all.

# OpenAI: intent extraction + Realtime voice. Without it, text search
# still works via the built-in deterministic parser.
OPENAI_API_KEY=

# Optional model overrides
# OPENAI_INTENT_MODEL=gpt-4o-mini
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=nova

# Voice mode: "simple" (default; record -> Whisper -> text flow -> TTS)
# or "realtime" (OpenAI Realtime WebRTC agent)
# NEXT_PUBLIC_VOICE_MODE=simple

# SerpAPI (Google Shopping discovery). Either variable name works.
SERPAPI_API_KEY=
# SERF_API=

# DataForSEO Merchant API (second Google Shopping source, often with
# direct merchant URLs). Value is base64("login:password") from the
# DataForSEO dashboard. The account must be verified at app.dataforseo.com.
DATAFORSEO_API_KEY_BASE64=

# live  = external providers only
# hybrid = external providers + deterministic demo offers (recommended)
# demo  = deterministic local data only (works offline)
SEARCH_MODE=hybrid

NEXT_PUBLIC_APP_URL=http://localhost:3000
